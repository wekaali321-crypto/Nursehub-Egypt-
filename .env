# NurseHub Egypt — Environment Variables
# Copy this file to .env and fill in your real Supabase credentials.
# IMPORTANT: Never commit .env to version control.

# ============================================
# REQUIRED: Supabase Connection
# ============================================
# Get these values from: https://supabase.com/dashboard/project/_/settings/api
#
# SUPABASE_URL should be your project URL (e.g., https://xxx.supabase.co)
# SUPABASE_PUBLISHABLE_KEY should be your anon/publishable key
#
# Vite requires the VITE_ prefix to expose env vars to the browser.
# Both formats are supported — use whichever is easier.

SUPABASE_URL=https://kavddqbyicahmbrbcdam.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_C120cDnqIO4V4m-WcSQtLg_TsEBov6z

# Also provide Vite-prefixed versions (recommended for Vite builds)
VITE_SUPABASE_URL=https://kavddqbyicahmbrbcdam.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_C120cDnqIO4V4m-WcSQtLg_TsEBov6z

# Legacy compatibility (optional)
VITE_SUPABASE_ANON_KEY=sb_publishable_C120cDnqIO4V4m-WcSQtLg_TsEBov6z

# ============================================
# Optional: First Admin Account
# ============================================
# VITE_ADMIN_EMAIL=admin@nursehub.eg
# VITE_ADMIN_PASSWORD_HASH=pbkdf2$210000$...

# ============================================
# Optional: Payment Gateways (disabled until keys added)
# ============================================
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# VITE_PAYMOB_API_KEY=...
# VITE_PAYMOB_INTEGRATION_ID=...
# VITE_FAWRY_MERCHANT_CODE=...

# ============================================
# Optional: Email & Analytics
# ============================================
# VITE_RESEND_API_KEY=...
# VITE_GA_MEASUREMENT_ID=G-...
