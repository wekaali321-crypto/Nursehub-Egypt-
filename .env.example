# انسخ هذا الملف إلى .env واملأ القيم

# --- Supabase (Project Settings -> API) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- حساب المدير الأول (اختياري) ---
# اضبطه لتخطي صفحة الإعداد الأولي. لا تضع كلمة المرور الصريحة أبداً — فقط الهاش.
# لتوليد الهاش، نفّذ في وحدة تحكم المتصفح على الموقع:
#   import("/src/lib/auth.ts").then(m => m.hashPassword("YourStrongPassword").then(console.log))
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD_HASH=
